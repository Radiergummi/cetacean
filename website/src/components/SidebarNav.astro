---
import { sidebarGroups } from "../lib/navigation";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
---

<nav class="text-[0.8125rem]">
  {sidebarGroups.map((group) => (
    <div class="mb-8">
      <h3 class="text-[0.6875rem] font-semibold uppercase tracking-widest text-muted-foreground mb-3 px-3">
        {group.label}
      </h3>
      <ul class="space-y-0.5">
        {group.items.map(({ slug, title }) => (
          <li>
            <a
              href={`/${slug}`}
              class:list={[
                "block rounded-md px-3 py-1.5 transition-colors",
                currentSlug === slug
                  ? "bg-accent font-medium"
                  : "text-muted-foreground hover:text-foreground hover:bg-accent/60",
              ]}
              style={currentSlug === slug ? `color: var(--active)` : undefined}
            >
              {title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
  <div class="border-t border-border pt-6 mt-2">
    <a
      href="/changelog"
      class:list={[
        "block rounded-md px-3 py-1.5 transition-colors",
        currentSlug === "changelog"
          ? "bg-accent font-medium"
          : "text-muted-foreground hover:text-foreground hover:bg-accent/60",
      ]}
      style={currentSlug === "changelog" ? `color: var(--active)` : undefined}
    >
      Changelog
    </a>
  </div>
</nav>
