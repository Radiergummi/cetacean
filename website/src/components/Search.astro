---
---
<div class="flex-1 hidden md:flex justify-center px-4">
  <button
    id="search-trigger"
    type="button"
    class="inline-flex items-center gap-2 rounded-md border border-border bg-muted/50 px-2.5 py-1 text-sm text-muted-foreground hover:bg-muted transition-colors cursor-pointer w-full max-w-2xs lg:max-w-xs justify-between"
  >
    <span class="flex items-center gap-2">
      <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
      </svg>
      Search...
    </span>
    <kbd class="pointer-events-none text-[0.6875rem] font-medium text-muted-foreground/70" id="search-shortcut-label"></kbd>
  </button>
</div>


<div id="search-overlay" class="search-overlay" hidden transition:persist>
  <div class="search-backdrop" aria-hidden="true"></div>
  <div class="search-dialog" role="dialog" aria-modal="true" aria-label="Search documentation">
    <div class="search-input-row">
      <svg class="size-4 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Search documentation..."
        autocomplete="off"
        aria-label="Search"
        class="flex-1 bg-transparent text-sm outline-none placeholder:text-muted-foreground"
      />
      <kbd class="text-[0.625rem] font-medium text-muted-foreground/60 border border-border rounded px-1 py-0.5 leading-none">ESC</kbd>
    </div>
    <div id="search-results" class="search-results"></div>
    <div id="search-status" class="sr-only" aria-live="polite" role="status"></div>
  </div>
</div>

<script is:inline>
  if (!window.__searchInitialized) {
    window.__searchInitialized = true;

    let activeIndex = -1;
    let debounceTimer = null;
    let pendingQuery = null;
    let pagefindPromise = null;
    let previouslyFocused = null;

    const loadPagefind = () => {
      if (!pagefindPromise) {
        pagefindPromise = import("/pagefind/pagefind.js").catch(() => {
          pagefindPromise = null;
          return null;
        });
      }
      return pagefindPromise;
    };

    const getOverlay = () => document.getElementById("search-overlay");
    const getInput = () => document.getElementById("search-input");
    const getResults = () => document.getElementById("search-results");
    const getStatus = () => document.getElementById("search-status");

    const open = () => {
      previouslyFocused = document.activeElement;
      const overlay = getOverlay();
      const input = getInput();
      const results = getResults();
      overlay.hidden = false;
      input.value = "";
      results.innerHTML = "";
      activeIndex = -1;
      loadPagefind();
      requestAnimationFrame(() => input.focus());
    };

    const close = () => {
      const overlay = getOverlay();
      overlay.hidden = true;
      getInput()?.blur();
      if (previouslyFocused && previouslyFocused.focus) {
        previouslyFocused.focus();
        previouslyFocused = null;
      }
    };

    document.addEventListener("click", (e) => {
      if (e.target.closest("#search-trigger") || e.target.closest("#search-trigger-mobile")) {
        open();
      }
      if (e.target.closest(".search-backdrop")) {
        close();
      }
    });

    const getItems = () => getResults().querySelectorAll("[data-search-item]");

    const setActive = (index) => {
      const items = getItems();
      items.forEach((el) => el.removeAttribute("data-active"));
      activeIndex = index;
      if (index >= 0 && index < items.length) {
        items[index].setAttribute("data-active", "");
        items[index].scrollIntoView({ block: "nearest" });
      }
    };

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        getOverlay().hidden ? open() : close();
        return;
      }
      const overlay = getOverlay();
      if (overlay.hidden) return;
      if (e.key === "Escape") {
        close();
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive(Math.min(activeIndex + 1, getItems().length - 1));
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(Math.max(activeIndex - 1, 0));
      } else if (e.key === "Enter" && activeIndex >= 0 && activeIndex < getItems().length) {
        e.preventDefault();
        const link = getItems()[activeIndex].querySelector("a");
        if (link) window.location.href = link.href;
      }
    });

    document.addEventListener("input", (e) => {
      if (e.target.id !== "search-input") return;
      clearTimeout(debounceTimer);
      const query = e.target.value.trim();
      if (!query) {
        getResults().innerHTML = "";
        getStatus().textContent = "";
        activeIndex = -1;
        pendingQuery = null;
        return;
      }
      pendingQuery = query;
      debounceTimer = setTimeout(() => doSearch(query), 150);
    });

    const doSearch = async (query) => {
      const pagefind = await loadPagefind();
      const resultsContainer = getResults();
      if (!pagefind) {
        resultsContainer.innerHTML = '<div class="search-empty">Search unavailable — run <code>npm run build</code> to generate the index.</div>';
        return;
      }
      const search = await pagefind.search(query);
      if (pendingQuery !== query) return;
      const loaded = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));
      if (pendingQuery !== query) return;

      if (!loaded.length) {
        resultsContainer.innerHTML = '<div class="search-empty">No results found.</div>';
        getStatus().textContent = "No results found.";
        activeIndex = -1;
        return;
      }

      resultsContainer.innerHTML = "";
      for (const item of loaded) {
        const row = document.createElement("div");
        row.setAttribute("data-search-item", "");
        row.className = "search-item";

        const link = document.createElement("a");
        link.href = item.url;
        link.className = "search-item-link";

        const title = document.createElement("span");
        title.className = "search-item-title";
        title.textContent = item.meta.title || "";

        const excerpt = document.createElement("span");
        excerpt.className = "search-item-excerpt";
        excerpt.innerHTML = item.excerpt || "";

        link.append(title, excerpt);
        row.appendChild(link);
        resultsContainer.appendChild(row);
      }

      activeIndex = -1;
      setActive(0);
      getStatus().textContent = loaded.length + " result" + (loaded.length === 1 ? "" : "s") + " found.";
    };
  }

  // Move overlay to body on initial load (persists across navigations via transition:persist).
  const overlay = document.getElementById("search-overlay");
  if (overlay?.parentElement !== document.body) document.body.appendChild(overlay);

  const label = document.getElementById("search-shortcut-label");
  if (label) {
    label.textContent = /Mac|iPod|iPhone|iPad/.test(navigator.platform || "") ? "⌘K" : "Ctrl+K";
  }
</script>
