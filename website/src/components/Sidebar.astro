---
import SidebarNav from "./SidebarNav.astro";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
---

<aside class="hidden md:block w-60 shrink-0 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto py-8 pl-6 lg:pl-8 pr-6" aria-label="Documentation sidebar">
  <SidebarNav currentSlug={currentSlug} />
</aside>

<div id="mobile-sidebar" class="mobile-sidebar-overlay fixed inset-0 z-40 pointer-events-none md:hidden" role="dialog" aria-modal="true" aria-label="Navigation menu" aria-hidden="true">
  <div id="mobile-sidebar-backdrop" class="mobile-sidebar-backdrop absolute inset-0" aria-hidden="true"></div>
  <aside class="mobile-sidebar-panel absolute right-0 top-0 w-72 h-full bg-background border-l border-border overflow-y-auto pt-20 pb-8 px-6 shadow-xl">
    <SidebarNav currentSlug={currentSlug} />
  </aside>
</div>

<script is:inline>
  if (!window.__sidebarInitialized) {
    window.__sidebarInitialized = true;

    const getSidebar = () => document.getElementById("mobile-sidebar");
    const getToggle = () => document.getElementById("mobile-menu-toggle");

    const openSidebar = (sidebar) => {
      sidebar.classList.add("open");
      sidebar.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      getToggle()?.setAttribute("aria-expanded", "true");
      var firstLink = sidebar.querySelector("a[href]");
      if (firstLink) requestAnimationFrame(() => firstLink.focus());
    };

    const closeSidebar = (sidebar) => {
      sidebar.classList.remove("open");
      sidebar.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      var toggle = getToggle();
      if (toggle) {
        toggle.setAttribute("aria-expanded", "false");
        toggle.focus();
      }
    };

    document.addEventListener("click", (e) => {
      const sidebar = getSidebar();
      if (!sidebar) return;

      if (e.target.closest("#mobile-menu-toggle")) {
        if (sidebar.classList.contains("open")) {
          closeSidebar(sidebar);
        } else {
          openSidebar(sidebar);
        }
      }
      if (e.target.closest("#mobile-sidebar-backdrop")) {
        closeSidebar(sidebar);
      }
    });

    document.addEventListener("keydown", (e) => {
      const sidebar = getSidebar();
      if (!sidebar || !sidebar.classList.contains("open")) return;
      if (e.key === "Escape") {
        closeSidebar(sidebar);
      } else if (e.key === "Tab") {
        var panel = sidebar.querySelector(".mobile-sidebar-panel");
        var focusable = panel.querySelectorAll('input, button, a[href], [tabindex]:not([tabindex="-1"])');
        if (focusable.length) {
          var first = focusable[0];
          var last = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }
    });

    document.addEventListener("astro:page-load", () => {
      const sidebar = getSidebar();
      if (sidebar) {
        sidebar.classList.remove("open");
        sidebar.setAttribute("aria-hidden", "true");
      }
      document.body.style.overflow = "";
      var toggle = getToggle();
      if (toggle) toggle.setAttribute("aria-expanded", "false");
    });
  }
</script>
