---
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description: string;
  isHome?: boolean;
  lastModified?: Date | null;
}

const { title, description, isHome = false, lastModified } = Astro.props;

const siteName = "Cetacean";
const fullTitle = isHome ? `${siteName} — ${description}` : `${title} — ${siteName}`;
const pathname = Astro.url.pathname.replace(/\/index\.html$/, "/");
const canonicalUrl = new URL(pathname, Astro.site).href;

const jsonLd: Record<string, unknown> = isHome
  ? {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: siteName,
      description,
      url: canonicalUrl,
    }
  : {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      name: title,
      headline: title,
      description,
      url: canonicalUrl,
      isPartOf: { "@type": "WebSite", name: siteName, url: Astro.site?.href },
      ...(lastModified && { dateModified: lastModified.toISOString() }),
    };

const breadcrumbLd = !isHome ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: siteName, item: Astro.site?.href },
    { "@type": "ListItem", position: 2, name: title },
  ],
} : null;

const ldScripts = [jsonLd, breadcrumbLd].filter(Boolean).map(
  (ld) => `<script type="application/ld+json">${JSON.stringify(ld).replace(/</g, "\\u003c")}</script>`
).join("\n");
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" type="application/atom+xml" title="Cetacean Releases" href="/changelog.atom" />

<meta property="og:type" content={isHome ? "website" : "article"} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />

<Fragment set:html={ldScripts} />

<ClientRouter />
<script is:inline>
  (function() {
    const theme = localStorage.getItem("theme") || "system";
    const dark = theme === "dark" || (theme === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
    if (dark) document.documentElement.classList.add("dark");
  })();
</script>
