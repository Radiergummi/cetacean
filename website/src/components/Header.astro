---
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navLinks = [
  { href: "/getting-started", label: "Docs" },
  { href: "/api", label: "API" },
];
---
<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur-lg">
  <div class="mx-auto flex h-16 max-w-[90rem] items-center px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2.5 text-foreground font-semibold mr-8">
      <span class="text-xl">🐋</span>
      <span class="text-[0.9375rem]">Cetacean</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "rounded-md px-3 py-1.5 text-sm transition-colors",
            currentPath.startsWith(href)
              ? "font-medium"
              : "text-muted-foreground hover:text-foreground",
          ]}
          style={currentPath.startsWith(href) ? "color: var(--active)" : undefined}
        >
          {label}
        </a>
      ))}
      <a
        href="https://github.com/Radiergummi/cetacean"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors"
      >
        GitHub
      </a>
    </nav>

    <div class="ml-auto flex items-center gap-1">
      <ThemeToggle />
      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden rounded-md p-2 text-muted-foreground hover:text-foreground hover:bg-accent transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="size-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>
</header>
