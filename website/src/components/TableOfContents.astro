---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---
{filtered.length > 0 && (
  <aside class="hidden xl:block w-48 shrink-0 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto py-8 pr-6 lg:pr-8 pl-4">
    <h3 class="text-[0.6875rem] font-semibold uppercase tracking-widest text-muted-foreground mb-4">
      On this page
    </h3>
    <ul id="toc-list" class="space-y-1.5 text-[0.8125rem] border-l border-border pl-3">
      {filtered.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              "block py-0.5 text-muted-foreground hover:text-foreground transition-colors leading-snug",
              heading.depth === 3 && "pl-3",
            ]}
            data-heading={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<script is:inline>
  (function() {
    var links = document.querySelectorAll("#toc-list a[data-heading]");
    if (!links.length) return;
    var headings = Array.from(links).map(function(link) {
      return { link: link, target: document.getElementById(link.dataset.heading) };
    }).filter(function(h) { return h.target; });
    var current = null;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          if (current) { current.classList.remove("font-medium"); current.style.color = ""; }
          var match = headings.find(function(h) { return h.target === entry.target; });
          if (match) {
            match.link.classList.add("font-medium");
            match.link.style.color = "var(--active)";
            current = match.link;
          }
        }
      });
    }, { rootMargin: "-80px 0px -80% 0px" });
    headings.forEach(function(h) { observer.observe(h.target); });
  })();
</script>
