---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filtered = headings.filter(({ depth }) => depth >= 2 && depth <= 3);
---

{filtered.length > 0 && (
  <aside class="hidden xl:block w-44 shrink-0 sticky top-14 h-[calc(100vh-3.5rem)] py-6 px-2">
    <h3 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-3">
      On this page
    </h3>
    <ul id="toc-list" class="space-y-1.5 text-sm">
      {filtered.map(({ depth, slug, text }) => (
        <li>
          <a
            href={`#${slug}`}
            data-slug={slug}
            class:list={[
              "block transition-colors text-muted-foreground hover:text-foreground",
              depth === 3 && "pl-3",
            ]}
          >
            {text}
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<script is:inline>
  (function () {
    var tocList = document.getElementById("toc-list");
    if (!tocList) return;

    var links = tocList.querySelectorAll("a[data-slug]");
    if (!links.length) return;

    var activeSlug = null;

    function setActive(slug) {
      if (slug === activeSlug) return;
      activeSlug = slug;

      for (var i = 0; i < links.length; i++) {
        var link = links[i];
        var isActive = link.getAttribute("data-slug") === slug;
        link.classList.toggle("text-foreground", isActive);
        link.classList.toggle("font-medium", isActive);
        link.classList.toggle("text-muted-foreground", !isActive);
      }
    }

    var observer = new IntersectionObserver(
      function (entries) {
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) {
            setActive(entries[i].target.id);
            break;
          }
        }
      },
      { rootMargin: "0px 0px -80% 0px", threshold: 0 }
    );

    for (var i = 0; i < links.length; i++) {
      var heading = document.getElementById(links[i].getAttribute("data-slug"));
      if (heading) observer.observe(heading);
    }
  })();
</script>
