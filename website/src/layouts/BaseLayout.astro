---
import Head from "../components/Head.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  slug: string;
  lastModified?: Date;
  breadcrumbCategory?: string;
  /** Force full page reload instead of View Transitions. */
  reload?: boolean;
}

const { title, description, slug, lastModified, breadcrumbCategory, reload } = Astro.props;
---
<html lang="en" {...(reload && { "data-astro-reload": true })}>
  <head>
    <Head title={title} description={description} lastModified={lastModified} breadcrumbCategory={breadcrumbCategory} />
    <slot name="head" />
  </head>
  <body class="min-h-screen">
    <Header currentPath={Astro.url.pathname} />
    <div class="mx-auto flex max-w-[90rem]">
      <Sidebar currentSlug={slug} />
      <slot />
    </div>
  </body>
</html>
