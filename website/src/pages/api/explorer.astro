---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="API Reference" description="Interactive API reference for the Cetacean REST API." slug="api/explorer">
  <style slot="head">
    .scalar-container {
      flex: 1;
      min-width: 0;
      min-height: calc(100vh - 4rem);
      height: calc(100% - 24px);
      --scalar-custom-header-height: 4rem;
    }
  </style>
  <div class="scalar-container" id="scalar-root"></div>
  <script is:inline>
    (function() {
      function isDark() {
        return document.documentElement.classList.contains("dark");
      }

      function applyThemeClasses() {
        const dark = isDark();
        document.body.classList.toggle("dark-mode", dark);
        document.body.classList.toggle("light-mode", !dark);
      }

      function init() {
        Scalar.createApiReference("#scalar-root", {
          url: "/openapi.yaml",
          hideDarkModeToggle: true,
          hideSearch: true,
          showOperationId: true,
          title: "Cetacean API Reference",
          telemetry: false,
          baseServerURL: 'https://cetacean.example.com',
          hideTestRequestButton: true,
          darkMode: isDark(),
          defaultHttpClient: {
            targetKey: 'http',
            clientKey: '1.1'
          },
          mcp: {
            disabled: true
          },
          hideClientButton: true,
          withDefaultFonts: false,
          agent: {
            disabled: true,
          },
          servers: [
            {
              url: 'https://{hostname}',
              variables: {
                hostname: {
                  default: 'cetacean.example.com'
                }
              }
            },
          ]
        });

        new MutationObserver(applyThemeClasses).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });

        // Scalar resets body classes during its Vue mount. Watch for that
        // and re-apply our theme classes, but only when they're actually missing.
        new MutationObserver(function() {
          var dark = isDark();
          var hasDark = document.body.classList.contains("dark-mode");
          var hasLight = document.body.classList.contains("light-mode");
          if (dark && !hasDark || !dark && !hasLight) {
            applyThemeClasses();
          }
        }).observe(document.body, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }

      if (typeof Scalar !== "undefined") {
        init();
      } else {
        const s = document.createElement("script");
        s.src = "/scalar.js";
        s.onload = init;
        document.head.appendChild(s);
      }
    })();
  </script>
</BaseLayout>
