---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="API Reference" description="Interactive API reference for the Cetacean REST API." slug="api/explorer">
  <style slot="head">
    .scalar-container {
      flex: 1;
      min-width: 0;
      min-height: calc(100vh - 4rem);
      height: calc(100% - 24px);
      --scalar-custom-header-height: 4rem;
    }
  </style>
  <div class="scalar-container" id="scalar-root"></div>
  <script is:inline>
    (function() {
      function isDark() {
        return document.documentElement.classList.contains("dark");
      }

      function applyThemeClasses() {
        var dark = isDark();
        document.body.classList.toggle("dark-mode", dark);
        document.body.classList.toggle("light-mode", !dark);
      }

      function init() {
        var ref = Scalar.createApiReference("#scalar-root", {
          url: "/openapi.yaml",
          hideDarkModeToggle: true,
          hideSearch: true,
          showOperationId: true,
          title: "Cetacean API Reference",
          telemetry: false,
          baseServerURL: 'https://cetacean.example.com',
          hideTestRequestButton: true,
          darkMode: isDark(),
          defaultHttpClient: {
            targetKey: 'http',
            clientKey: '1.1'
          },
          mcp: {
            disabled: true
          },
          hideClientButton: true,
          withDefaultFonts: false,
          agent: {
            disabled: true,
          },
          servers: [
            {
              url: 'https://{hostname}',
              variables: {
                hostname: {
                  default: 'cetacean.example.com'
                }
              }
            },
          ]
        });

        // Scalar overwrites body classes during its async Vue mount.
        // Poll briefly until our classes stick, then switch to observers.
        var attempts = 0;
        var poll = setInterval(function() {
          applyThemeClasses();
          if (++attempts >= 20) clearInterval(poll);
        }, 100);

        new MutationObserver(function() {
          applyThemeClasses();
          clearInterval(poll);
        }).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });

        // Clean up Scalar-specific body classes when leaving the page
        document.addEventListener("astro:before-swap", function cleanup() {
          clearInterval(poll);
          document.body.classList.remove("dark-mode", "light-mode");
          document.removeEventListener("astro:before-swap", cleanup);
        });
      }

      if (typeof Scalar !== "undefined") {
        init();
      } else {
        const s = document.createElement("script");
        s.src = "/scalar.js";
        s.onload = init;
        document.head.appendChild(s);
      }
    })();
  </script>
</BaseLayout>
