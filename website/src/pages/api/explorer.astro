---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="API Reference" description="Interactive API reference for the Cetacean REST API." slug="api/explorer" reload>
  <style slot="head">
    .scalar-container {
      flex: 1;
      min-width: 0;
      min-height: calc(100vh - 4rem);
    }
  </style>
  <div class="scalar-container">
    <script
      id="api-reference"
      data-url="/openapi.yaml"
      type="application/json"
      is:inline
      set:html={JSON.stringify({
        theme: "none",
        hideDownloadButton: false,
        hideDarkModeToggle: true,
      })}
    />
    <script is:inline src="/scalar.js"></script>
  </div>
</BaseLayout>
