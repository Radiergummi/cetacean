---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="API Reference" description="Interactive API reference for the Cetacean REST API." slug="api/explorer">
  <style slot="head">
    .scalar-container {
      flex: 1;
      min-width: 0;
      min-height: calc(100vh - 4rem);
    }
  </style>
  <div class="scalar-container" id="scalar-root"></div>
  <script>
    import { createApiReference } from "@scalar/api-reference";

    function isDark() {
      return document.documentElement.classList.contains("dark");
    }

    const ref = createApiReference("#scalar-root", {
      url: "/openapi.yaml",
      hideDarkModeToggle: true,
      hideSearch: true,
      showDeveloperTools: "never",
      darkMode: isDark(),
    });

    new MutationObserver(() => {
      ref.updateConfig({ darkMode: isDark() });
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  </script>
</BaseLayout>
