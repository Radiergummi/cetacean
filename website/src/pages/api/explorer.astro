---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="API Reference" description="Interactive API reference for the Cetacean REST API." slug="api/explorer">
  <style slot="head">
    .scalar-container {
      flex: 1;
      min-width: 0;
      min-height: calc(100vh - 4rem);
      height: calc(100% - 24px);
      --scalar-custom-header-height: 4rem;
    }
  </style>
  <div class="scalar-container" id="scalar-root"></div>
  <script is:inline>
    (function() {
      function isDark() {
        return document.documentElement.classList.contains("dark");
      }

      function applyThemeClasses() {
        const dark = isDark();
        document.body.classList.toggle("dark-mode", dark);
        document.body.classList.toggle("light-mode", !dark);
      }

      function init() {
        Scalar.createApiReference("#scalar-root", {
          url: "/openapi.yaml",
          hideDarkModeToggle: true,
          hideSearch: true,
          showOperationId: true,
          title: "Cetacean API Reference",
          telemetry: false,
          baseServerURL: "https://cetacean.example.com",
          hideTestRequestButton: true,
          darkMode: isDark(),
          defaultHttpClient: { targetKey: "http", clientKey: "1.1" },
          hiddenClients: ["ruby", "php", "c", "csharp", "clojure", "dart", "fsharp", "node.js", "objc", "r", "powershell", "ocaml", "kotlin"],
          mcp: { disabled: true },
          hideClientButton: true,
          withDefaultFonts: false,
          agent: { disabled: true },
          servers: [
            {
              url: "https://{hostname}",
              variables: { hostname: { default: "cetacean.example.com" } },
            },
          ],
        });

        // Scalar's async Vue mount may clobber body classes after we set them.
        // Poll briefly until our classes stick; the observer handles later toggles.
        let attempts = 0;
        const poll = setInterval(function() {
          applyThemeClasses();
          if (++attempts >= 20) clearInterval(poll);
        }, 100);

        const observer = new MutationObserver(applyThemeClasses);
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });

        document.addEventListener("astro:before-swap", function cleanup() {
          clearInterval(poll);
          observer.disconnect();
          document.body.classList.remove("dark-mode", "light-mode");
          document.removeEventListener("astro:before-swap", cleanup);
        }, { once: true });
      }

      if (typeof Scalar !== "undefined") {
        init();
      } else {
        const s = document.createElement("script");
        s.src = "/scalar.js";
        s.onload = init;
        document.head.appendChild(s);
      }
    })();
  </script>
</BaseLayout>
